# coding: utf-8

# ================================
# GPIO 라이브러리 임포트 (라즈베리파이 핀 제어)
# ================================
import RPi.GPIO as GPIO

# ================================
# Tkinter 라이브러리 임포트 (GUI 화면 출력)
# ================================
import tkinter as tk

# ================================
# GPIO 핀 번호 설정 (물리적 핀 번호 기준)
# ================================
GPIO.setmode(GPIO.BOARD)

# ================================
# 사용할 핀 번호 정의
# ================================
SW = 7     # 스위치 입력 핀
LED = 11   # LED 출력 핀

# ================================
# LED 핀 설정 (출력, 초기값 OFF)
# ================================
GPIO.setup(LED, GPIO.OUT, initial=GPIO.LOW)

# ================================
# 스위치 핀 설정 (입력 + 풀업 저항)
# 기본 상태 HIGH / 눌리면 LOW
# ================================
GPIO.setup(SW, GPIO.IN, pull_up_down=GPIO.PUD_UP)

# ================================
# Tkinter GUI 생성
# ================================
root = tk.Tk()
root.title("LED Control with Star GUI")

# ================================
# Canvas 생성 (도형 그릴 공간)
# ================================
c = tk.Canvas(root, width=200, height=200)
c.pack()

# ================================
# ★ 별 모양 좌표 정의 (5각 별)
# ================================
points = [
    100, 40,   # 위 꼭짓점
    120, 90,
    170, 90,
    130, 120,
    150, 170,
    100, 140,
    50, 170,
    70, 120,
    30, 90,
    80, 90
]

# ================================
# ★ 별 도형 생성 (초기: 비어있는 상태)
# ================================
cc = c.create_polygon(points, fill='')

# ================================
# 스위치 상태 변화 시 실행되는 함수
# ================================
def check_SW(channel):

    # 현재 스위치 상태 읽기
    key_in = GPIO.input(channel)

    # ============================
    # ★ 스위치 눌림 (LOW)
    # ============================
    if key_in == 0:
        GPIO.output(LED, GPIO.HIGH)      # LED ON (전류 흐름)
        c.itemconfig(cc, fill='yellow')  # ★ 별을 노란색으로 채움

    # ============================
    # ★ 스위치 안 눌림 (HIGH)
    # ============================
    else:
        GPIO.output(LED, GPIO.LOW)       # LED OFF
        c.itemconfig(cc, fill='')        # ★ 별 색 제거 (비어있게)

# ================================
# 이벤트 감지 설정
# 스위치 상태가 바뀔 때마다 함수 호출
# BOTH: 눌림/떼짐 모두 감지
# ================================
GPIO.add_event_detect(SW, GPIO.BOTH, callback=check_SW)

# ================================
# GUI 실행 (이벤트 대기 상태)
# ================================
root.mainloop()

# ================================
# 프로그램 종료 시 GPIO 자원 해제
# ================================
GPIO.cleanup()
